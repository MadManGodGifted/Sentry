NEXT_PUBLIC_SENTRY_APP_MODE=foundation

# Required for NASA Open APIs:
# APOD, NeoWs, Earth Imagery, EPIC, Mars Rover Photos, DONKI, and related NASA endpoints.
# Obtain a key from https://api.nasa.gov/
NEXT_PUBLIC_NASA_API_KEY=
NEXT_PUBLIC_NASA_API_BASE=https://api.nasa.gov
NEXT_PUBLIC_NASA_EONET_API_BASE=https://eonet.gsfc.nasa.gov/api/v3
NEXT_PUBLIC_NASA_TECHPORT_API_BASE=https://techport.nasa.gov/api

# Optional override endpoints. Leave empty unless an official provider endpoint changes.
NEXT_PUBLIC_SPACEX_API_BASE=https://api.spacexdata.com
NEXT_PUBLIC_CELESTRAK_API_BASE=https://celestrak.org
NEXT_PUBLIC_OPEN_METEO_API_BASE=https://api.open-meteo.com
NEXT_PUBLIC_NOAA_SWPC_API_BASE=https://services.swpc.noaa.gov
